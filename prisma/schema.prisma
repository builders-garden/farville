generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Collectible {
  id           Int                  @id @default(autoincrement())
  name         String?
  description  String?
  imageUrl     String
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  category     String?
  collectibles UserHasCollectible[]

  @@map("collectible")
}

model Item {
  id                 Int                 @id @default(autoincrement())
  name               String
  description        String?
  icon               String
  category           String
  buyPrice           Int?
  sellPrice          Int?
  requiredLevel      Int
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  slug               String              @unique
  clanQuests         ClanQuest[]
  clanRequests       ClanRequest[]
  quests             Quest[]
  requests           Request[]
  userGridCells      UserGridCell[]
  userHarvestedCrops UserHarvestedCrop[]
  userItems          UserHasItem[]
  vouchers           Voucher[]

  @@map("item")
}

model LeagueSnapshot {
  id        Int      @id(map: "leagues_snapshot_pkey") @default(autoincrement())
  week      Int
  snapshot  Json     @db.Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("league_snapshot")
}

model Quest {
  id         Int            @id @default(autoincrement())
  category   String
  itemId     Int?
  amount     Int            @default(1)
  xp         Int?
  coins      Int?
  startAt    DateTime       @db.Timestamptz(6)
  endAt      DateTime?      @db.Timestamptz(6)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  type       String
  level      Int
  mode       String         @default("classic")
  item       Item?          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "quest_itemid_fkey")
  userQuests UserHasQuest[]

  @@map("quest")
}

model Referral {
  id          Int      @id @default(autoincrement())
  fid         Int
  referredFid Int
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  user        User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@map("referral")
}

model Request {
  id             String       @id @default(dbgenerated("gen_random_uuid()"))
  fid            Int
  itemId         Int?
  quantity       Int
  filledQuantity Int
  createdAt      DateTime     @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  mode           String       @default("classic")
  clan           ClanRequest?
  user           User         @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item           Item?        @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "request_itemid_fkey")

  @@map("request")
}

model Streak {
  id           String      @id @default(dbgenerated("gen_random_uuid()"))
  fid          Int
  startedAt    DateTime    @db.Date
  endedAt      DateTime?   @db.Date
  lastActionAt DateTime    @db.Date
  lastClaimed  Int         @default(0)
  user         User        @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  userFrosts   UserFrost[]

  @@unique([fid, startedAt], map: "streak_fid_started_at_unique")
  @@map("streak")
}

model User {
  fid                    Int                     @id
  username               String
  displayName            String
  avatarUrl              String?
  walletAddress          String
  notificationDetails    Json?                   @db.Json
  mintedOG               Boolean                 @default(false)
  createdAt              DateTime                @default(now()) @db.Timestamptz(6)
  selectedAvatarUrl      String?
  bot                    String                  @default("unsafe")
  createdClans           Clan[]                  @relation("ClanCreator")
  leaderClans            Clan[]                  @relation("ClanLeader")
  ClanChatMessage        ClanChatMessage[]
  clan_join_request      ClanJoinRequest[]
  clan                   ClanMembership?
  clanRequests           ClanRequest[]
  clanStatistics         ClanUserStatistic[]
  referrals              Referral[]
  requests               Request[]
  streaks                Streak[]
  userCommunityDonations UserCommunityDonation[]
  donationsAsDonator     UserDonationHistory[]   @relation("user_donation_history_donatorFidTouser")
  donationsAsReceiver    UserDonationHistory[]   @relation("user_donation_history_receiverFidTouser")
  gridCells              UserGridCell[]
  harvestedCrops         UserHarvestedCrop[]
  collectibles           UserHasCollectible[]
  items                  UserHasItem[]
  quests                 UserHasQuest[]
  vouchers               UserHasVoucher[]
  leaderboardEntries     UserLeaderboardEntry[]
  notifications          UserNotification[]
  statistics             UserStatistic[]

  @@map("user")
}

model UserDonationHistory {
  donatorFid   Int      @default(autoincrement())
  receiverFid  Int
  times        Int?     @default(0)
  lastDonation DateTime @default(now()) @db.Timestamptz(6)
  mode         String   @default("classic")
  donatorUser  User     @relation("user_donation_history_donatorFidTouser", fields: [donatorFid], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "user_donation_history_donatorfid_fkey")
  receiverUser User     @relation("user_donation_history_receiverFidTouser", fields: [receiverFid], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "user_donation_history_receiverfid_fkey")

  @@id([donatorFid, receiverFid, mode])
  @@map("user_donation_history")
}

model UserFrost {
  id       String   @id @default(dbgenerated("gen_random_uuid()"))
  streakId String
  frozenAt DateTime @db.Date
  streak   Streak   @relation(fields: [streakId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_frost_streakid_fkey")

  @@unique([streakId, frozenAt], map: "user_frost_streak_frozen_unique")
  @@map("user_frost")
}

model UserGridCell {
  fid              Int
  x                Int
  y                Int
  mode             String    @default("classic")
  cropType         String?
  plantedAt        DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  speedBoostedAt   DateTime? @db.Timestamptz(6)
  harvestAt        DateTime? @db.Timestamptz(6)
  isReadyToHarvest Boolean   @default(false)
  item             Item?     @relation(fields: [cropType], references: [slug], onDelete: NoAction, onUpdate: NoAction, map: "user_grid_cell_croptype_fkey")
  user             User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, x, y, mode])
  @@map("user_grid_cell")
}

model UserHarvestedCrop {
  fid       Int
  crop      String
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  item      Item     @relation(fields: [crop], references: [slug], onDelete: NoAction, onUpdate: NoAction)
  user      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, crop], map: "user_harvested_crops_pkey")
  @@map("user_harvested_crop")
}

model UserHasCollectible {
  fid                Int
  collectibleId      Int
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  mintedImageUrl     String?
  mintedMetadataUrl  String?
  txHash             String?
  status             String      @default("description")
  generatedImageUrls Json?       @db.Json
  updatedAt          DateTime    @default(now()) @db.Timestamptz(6)
  generatedTaskId    String?
  pfpDescription     String?
  collectible        Collectible @relation(fields: [collectibleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_collectible_collectibleid_fkey")
  user               User        @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, collectibleId], map: "user_has_collectibles_pkey")
  @@map("user_has_collectible")
}

model UserHasItem {
  fid       Int
  itemId    Int
  mode      String   @default("classic")
  quantity  Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_item_itemid_fkey")

  @@id([fid, itemId, mode])
  @@map("user_has_item")
}

model UserHasQuest {
  fid         Int
  questId     Int
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  progress    Int
  status      String    @default("incomplete")
  user        User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_quest_questid_fkey")

  @@id([fid, questId])
  @@index([fid], map: "idx_user_has_quests_fid")
  @@index([questId], map: "idx_user_has_quests_quest_id")
  @@index([fid, status], map: "quests_by_fid_status")
  @@index([fid], map: "user_has_quests_fid_idx")
  @@index([questId], map: "user_has_quests_quest_id_idx")
  @@map("user_has_quest")
}

model UserLeaderboardEntry {
  fid          Int
  currentScore Int      @default(0)
  lastScore    Int      @default(0)
  league       Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  lastLeague   Int      @default(0)
  mode         String   @default("classic")
  user         User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, mode])
  @@map("user_leaderboard_entry")
}

model UserStatistic {
  fid        Int
  mode       String
  xp         Int
  coins      Int
  expansions Int
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, mode])
  @@map("user_statistic")
}

model UserNotification {
  id        Int      @id @default(autoincrement())
  fid       Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  category  String   @db.VarChar
  user      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_notification")
}

model Voucher {
  id           Int              @id @default(autoincrement())
  slug         String           @unique
  name         String
  description  String
  mode         String
  quantity     Int
  itemId       Int
  createdAt    DateTime         @default(now()) @db.Timestamptz(6)
  userVouchers UserHasVoucher[]
  item         Item             @relation(fields: [itemId], references: [id], onDelete: Cascade, map: "voucher_itemid_fkey")

  @@map("voucher")
}

model UserHasVoucher {
  fid           Int
  voucherId     Int
  claimedAmount Int
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  user          User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)
  voucher       Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "user_has_voucher_voucherid_fkey")

  @@id([fid, voucherId])
  @@map("user_has_voucher")
}

model UserCommunityDonation {
  id                 String                        @id @default(dbgenerated("gen_random_uuid()"))
  txHash             String
  mode               String                        @default("classic")
  fid                Int
  dollarAmount       Float
  ptAmount           Float
  message            String?
  createdAt          DateTime                      @default(now()) @db.Timestamptz(6)
  walletAddress      String
  lastStageDonations UserCommunityBoosterHistory[]
  user               User                          @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_community_donation")
}

model UserCommunityBoosterHistory {
  id           String                 @id @default(dbgenerated("gen_random_uuid()"))
  mode         String                 @default("classic")
  stage        Int
  lastDonation String?
  createdAt    DateTime               @default(now()) @db.Timestamptz(6)
  donation     UserCommunityDonation? @relation(fields: [lastDonation], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_community_booster_history_last_donation_fkey")

  @@map("user_community_booster_history")
}

model CommunityBoosterPoints {
  points Int    @id
  mode   String @default("classic")
  combo  Int    @default(1)

  @@map("community_booster_points")
}

model Clan {
  id             String              @id @default(dbgenerated("gen_random_uuid()"))
  name           String              @unique
  motto          String
  createdBy      Int
  leaderFid      Int
  imageUrl       String?
  isPublic       Boolean             @default(false)
  maxMembers     Int                 @default(20)
  xp             Int                 @default(0)
  seasonXp       Int                 @default(0)
  lastSeasonXp   Int                 @default(0)
  txHash         String?
  createdAt      DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime            @default(now()) @db.Timestamptz(6)
  requiredLevel  Int?
  creator        User                @relation("ClanCreator", fields: [createdBy], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "clan_created_by_fkey")
  leader         User                @relation("ClanLeader", fields: [leaderFid], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "clan_leader_fid_fkey")
  chatMessages   ClanChatMessage[]
  quests         ClanHasQuest[]
  joinRequests   ClanJoinRequest[]
  members        ClanMembership[]
  requests       ClanRequest[]
  userStatistics ClanUserStatistic[]

  @@map("clan")
}

model ClanMembership {
  fid           Int      @id
  clanId        String
  role          String   @default("member")
  joinedAt      DateTime @default(now()) @db.Timestamptz(6)
  xpContributed Int      @default(0)
  clan          Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_membership_clanid_fkey")
  user          User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "clan_membership_fid_fkey")

  @@index([clanId], map: "idx_clan_membership_clanid")
  @@map("clan_membership")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model ClanJoinRequest {
  id        String   @id(map: "clan_invite_pkey") @default(dbgenerated("gen_random_uuid()"))
  clanId    String
  fid       Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  clan      Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_invite_clanid_fkey")
  user      User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "clan_invite_fid_fkey")

  @@unique([clanId, fid], map: "clan_invite_clanid_fid_key")
  @@map("clan_join_request")
}

model ClanRequest {
  requestId String?  @unique
  clanId    String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  itemId    Int?
  quantity  Int?
  fid       Int
  clan      Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_request_clanid_fkey")
  user      User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "clan_request_fid_fkey")
  item      Item?    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "clan_request_itemid_fkey")
  request   Request? @relation(fields: [requestId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_request_requestid_fkey")

  @@map("clan_request")
}

model ClanQuest {
  id         String         @id @default(dbgenerated("gen_random_uuid()"))
  itemId     Int
  amount     Int            @default(1)
  xp         Int
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  category   String
  endAt      DateTime?      @db.Timestamptz(6)
  startAt    DateTime       @db.Timestamptz(6)
  clanQuests ClanHasQuest[]
  item       Item           @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "clan_quest_itemid_fkey")

  @@map("clan_quest")
}

model ClanHasQuest {
  clanId      String
  questId     String
  progress    Int       @default(0)
  status      String    @default("incomplete")
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  clan        Clan      @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_has_quest_clanid_fkey")
  quest       ClanQuest @relation(fields: [questId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_has_quest_questid_fkey")

  @@id([clanId, questId])
  @@map("clan_has_quest")
}

model ClanUserStatistic {
  fid                           Int
  clanId                        String
  generatedXp                   Int
  donations                     Int      @default(0)
  donatedCropsToOtherPlayers    Int      @default(0)
  donatedCropsToQuests          Int      @default(0)
  lastActivity                  DateTime @default(now()) @db.Timestamptz(6)
  createdAt                     DateTime @default(now()) @db.Timestamptz(6)
  receivedCropsFromOtherPlayers Int      @default(0)
  clan                          Clan     @relation(fields: [clanId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user                          User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, clanId])
  @@map("clan_user_statistic")
}

model ClanChatMessage {
  id        String   @id @default(dbgenerated("gen_random_uuid()"))
  clanId    String
  fid       Int
  message   String
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  clan      Clan     @relation(fields: [clanId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "clan_chat_message_clanid_fkey")
  user      User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "clan_chat_message_fid_fkey")

  @@index([clanId, createdAt], map: "idx_clan_chat_message_clan_time")
  @@map("clan_chat_message")
}
