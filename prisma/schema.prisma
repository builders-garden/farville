generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  fid                 Int                @id @db.Integer
  username            String
  displayName         String
  avatarUrl           String?
  walletAddress       String?
  xp                  Int                @default(0) @db.Integer
  coins               Int                @default(0) @db.Integer
  expansions          Int                @default(0) @db.Integer
  notificationDetails String?
  createdAt           DateTime           @default(now()) @db.Timestamptz(6)
  referrals           Referral[]         @relation("Referrer")
  requests            Request[]
  gridCells           GridCell[]
  items               UserHasItem[]
  quests              UserHasQuest[]
  notifications       UserNotification[]

  @@map("users")
}

model Item {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  icon          String
  category      String
  buyPrice      Int?          @db.Integer
  sellPrice     Int?          @db.Integer
  requiredLevel Int           @default(1) @db.Integer
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  slug          String        @unique
  quests        Quest[]
  requests      Request[]
  GridCell      GridCell[]
  userItems     UserHasItem[]

  @@map("items")
}

model UserHasItem {
  userFid   Int      @db.Integer
  itemId    Int
  quantity  Int      @default(1) @db.Integer
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userFid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@id([userFid, itemId])
  @@map("user_has_items")
}

model Referral {
  id          Int      @id @default(autoincrement())
  fid         Int      @db.Integer
  referredFid Int      @db.Integer
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  referrer    User     @relation("Referrer", fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@map("referrals")
}

model GridCell {
  fid              Int       @db.Integer
  x                Int
  y                Int
  cropType         String?
  plantedAt        DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  isReadyToHarvest Boolean   @default(false)
  yieldBoost       Int?      @db.Integer
  speedBoostedAt   DateTime? @db.Timestamptz(6)
  harvestAt        DateTime? @db.Timestamptz(6)
  user             User      @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "player_grid_cells_fid_fkey")
  crop             Item?     @relation(fields: [cropType], references: [slug], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, x, y])
  @@map("user_grid_cells")
}

model UserNotification {
  id         Int      @id @default(autoincrement())
  fid        Int      @db.Integer
  created_at DateTime @default(now()) @db.Timestamptz(6)
  category   String   @db.VarChar
  user       User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_notification")
}

model Request {
  id             Int      @id @default(autoincrement())
  fid            Int      @db.Integer
  itemId         Int?
  quantity       Int?     @db.Integer
  filledQuantity Int      @default(0) @db.Integer
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  user           User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item           Item?    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("requests")
}

model Quest {
  id         Int            @id @default(autoincrement())
  category   String
  itemId     Int?
  amount     Int?           @db.Integer
  xp         Int?           @db.Integer
  coins      Int?           @db.Integer
  startAt    DateTime       @db.Timestamptz(6)
  endAt      DateTime?      @db.Timestamptz(6)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  type       String?
  level      Int?           @db.Integer
  item       Item?          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userQuests UserHasQuest[]

  @@map("quests")
}

model UserHasQuest {
  id          Int       @id @default(autoincrement())
  fid         Int       @db.Integer
  questId     Int
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  progress    Int       @default(0) @db.Integer
  status      String    @default("incomplete")
  user        User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([fid, questId], map: "user_has_quests_fid_quest_id_key")
  @@index([fid], map: "idx_user_has_quests_fid")
  @@index([questId], map: "idx_user_has_quests_quest_id")
  @@index([fid])
  @@index([questId], map: "user_has_quests_quest_id_idx")
  @@map("user_has_quests")
}

enum UserHasQuestStatus {
  incomplete
  completed
  claimed
}
