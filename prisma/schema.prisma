generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  fid                 Int                @id
  username            String
  displayName         String
  avatarUrl           String?
  walletAddress       String?
  xp                  Int
  coins               Int
  expansions          Int
  notificationDetails String?
  createdAt           DateTime           @default(now()) @db.Timestamptz(6)
  referrals           Referral[]
  requests            Request[]
  user_grid_cells     GridCell[]
  user_has_items      UserHasItem[]
  user_has_quests     UserHasQuest[]
  user_notification   UserNotification[]

  @@map("users")
}

model Item {
  id             Int           @id @default(autoincrement())
  name           String
  description    String?
  icon           String
  category       String
  buyPrice       Int?
  sellPrice      Int?
  requiredLevel  Int
  createdAt      DateTime      @default(now()) @db.Timestamptz(6)
  slug           String?       @unique
  quests         Quest[]
  requests       Request[]
  GridCell       GridCell[]
  user_has_items UserHasItem[]

  @@map("items")
}

model UserHasItem {
  userFid   Int
  itemId    Int
  quantity  Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  items     Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users     User     @relation(fields: [userFid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([userFid, itemId])
  @@map("user_has_items")
}

model Referral {
  id          Int      @id @default(autoincrement())
  fid         Int
  referredFid Int
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  users       User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@map("referrals")
}

model GridCell {
  fid              Int
  x                Int
  y                Int
  cropType         String?
  plantedAt        DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  isReadyToHarvest Boolean   @default(false)
  yieldBoost       Int?
  speedBoostedAt   DateTime? @db.Timestamptz(6)
  harvestAt        DateTime? @db.Timestamptz(6)
  crop             Item?     @relation(fields: [cropType], references: [slug], onDelete: NoAction, onUpdate: NoAction)
  users            User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, x, y])
  @@map("user_grid_cells")
}

model UserNotification {
  id         Int      @id @default(autoincrement())
  fid        Int
  created_at DateTime @default(now()) @db.Timestamptz(6)
  category   String   @db.VarChar
  users      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@map("user_notification")
}

model Request {
  id             Int      @id @default(autoincrement())
  fid            Int
  itemId         Int?
  quantity       Int?
  filledQuantity Int
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  users          User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  items          Item?    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("requests")
}

model Quest {
  id              Int            @id @default(autoincrement())
  category        String
  itemId          Int?
  amount          Int?
  xp              Int?
  coins           Int?
  startAt         DateTime       @db.Timestamptz(6)
  endAt           DateTime?      @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @db.Timestamptz(6)
  type            String?
  level           Int?
  items           Item?          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user_has_quests UserHasQuest[]

  @@map("quests")
}

model UserHasQuest {
  id          Int       @id @default(autoincrement())
  fid         Int
  questId     Int
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  progress    Int
  status      String    @default("incomplete")
  users       User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  quests      Quest     @relation(fields: [questId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([fid, questId], map: "user_has_quests_fid_quest_id_key")
  @@index([fid], map: "idx_user_has_quests_fid")
  @@index([questId], map: "idx_user_has_quests_quest_id")
  @@index([fid])
  @@index([questId], map: "user_has_quests_quest_id_idx")
  @@map("user_has_quests")
}

enum UserHasQuestStatus {
  incomplete
  completed
  claimed
}
