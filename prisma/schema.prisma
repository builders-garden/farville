generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Collectible {
  id           Int                  @id @default(autoincrement())
  name         String?
  description  String?
  imageUrl     String
  createdAt    DateTime             @default(now()) @db.Timestamptz(6)
  category     String?
  collectibles UserHasCollectible[]

  @@map("collectible")
}

model Item {
  id                 Int                 @id @default(autoincrement())
  name               String
  description        String?
  icon               String
  category           String
  buyPrice           Int?
  sellPrice          Int?
  requiredLevel      Int
  createdAt          DateTime            @default(now()) @db.Timestamptz(6)
  slug               String              @unique
  quests             Quest[]
  requests           Request[]
  userGridCells      UserGridCell[]
  userHarvestedCrops UserHarvestedCrop[]
  userItems          UserHasItem[]

  @@map("item")
}

model LeagueSnapshot {
  id        Int      @id @default(autoincrement())
  week      Int
  snapshot  Json     @db.Json
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@map("league_snapshot")
}

model Quest {
  id         Int            @id @default(autoincrement())
  category   String
  itemId     Int?
  amount     Int            @default(1)
  xp         Int?
  coins      Int?
  startAt    DateTime       @db.Timestamptz(6)
  endAt      DateTime?      @db.Timestamptz(6)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  type       String
  level      Int
  item       Item?          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "quest_itemid_fkey")
  userQuests UserHasQuest[]

  @@map("quest")
}

model Referral {
  id          Int      @id @default(autoincrement())
  fid         Int
  referredFid Int
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  user        User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@map("referral")
}

model Request {
  id             Int      @id @default(autoincrement())
  fid            Int
  itemId         Int?
  quantity       Int?
  filledQuantity Int
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  user           User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item           Item?    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "request_itemid_fkey")

  @@map("request")
}

model Streak {
  id           Int         @id @default(autoincrement())
  fid          Int
  startedAt    DateTime    @db.Date
  endedAt      DateTime?   @db.Date
  lastActionAt DateTime    @db.Date
  lastClaimed  Int         @default(0)
  user         User        @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  userFrosts   UserFrost[]

  @@unique([fid, startedAt], map: "streak_fid_started_at_unique")
  @@map("streak")
}

model User {
  fid                 Int                    @id
  username            String
  displayName         String
  avatarUrl           String?
  walletAddress       String
  notificationDetails Json?                  @db.Json
  mintedOG            Boolean                @default(false)
  createdAt           DateTime               @default(now()) @db.Timestamptz(6)
  selectedAvatarUrl   String?
  referrals           Referral[]
  requests            Request[]
  streaks             Streak[]
  donationsAsDonator  UserDonationHistory[]  @relation("user_donation_history_donatorFidTouser")
  donationsAsReceiver UserDonationHistory[]  @relation("user_donation_history_receiverFidTouser")
  gridCells           UserGridCell[]
  harvestedCrops      UserHarvestedCrop[]
  collectibles        UserHasCollectible[]
  items               UserHasItem[]
  quests              UserHasQuest[]
  leaderboardEntry    UserLeaderboardEntry[]
  user_statistic      UserStatistic[]

  @@map("user")
}

model UserDonationHistory {
  donatorFid   Int      @default(autoincrement())
  receiverFid  Int
  times        Int?     @default(0)
  lastDonation DateTime @default(now()) @db.Timestamptz(6)
  donatorUser  User     @relation("user_donation_history_donatorFidTouser", fields: [donatorFid], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "user_donation_history_donatorfid_fkey")
  receiverUser User     @relation("user_donation_history_receiverFidTouser", fields: [receiverFid], references: [fid], onDelete: NoAction, onUpdate: NoAction, map: "user_donation_history_receiverfid_fkey")

  @@id([donatorFid, receiverFid])
  @@map("user_donation_history")
}

model UserFrost {
  id       Int      @id @default(autoincrement())
  streakId Int
  frozenAt DateTime @db.Date
  streak   Streak   @relation(fields: [streakId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_frost_streakid_fkey")

  @@unique([streakId, frozenAt], map: "user_frost_streak_frozen_unique")
  @@map("user_frost")
}

model UserGridCell {
  fid            Int
  x              Int
  y              Int
  mode           String
  cropType       String?
  plantedAt      DateTime? @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  speedBoostedAt DateTime? @db.Timestamptz(6)
  harvestAt      DateTime? @db.Timestamptz(6)
  item           Item?     @relation(fields: [cropType], references: [slug], onDelete: NoAction, onUpdate: NoAction, map: "user_grid_cell_croptype_fkey")
  user           User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, x, y, mode])
  @@map("user_grid_cell")
}

model UserHarvestedCrop {
  fid       Int
  crop      String
  quantity  Int      @default(0)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  item      Item     @relation(fields: [crop], references: [slug], onDelete: NoAction, onUpdate: NoAction)
  user      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, crop])
  @@map("user_harvested_crop")
}

model UserHasCollectible {
  fid                Int
  collectibleId      Int
  createdAt          DateTime    @default(now()) @db.Timestamptz(6)
  mintedImageUrl     String?
  mintedMetadataUrl  String?
  txHash             String?
  status             String      @default("description")
  generatedImageUrls Json?       @db.Json
  updatedAt          DateTime    @default(now()) @db.Timestamptz(6)
  generatedTaskId    String?
  pfpDescription     String?
  collectible        Collectible @relation(fields: [collectibleId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_collectible_collectibleid_fkey")
  user               User        @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, collectibleId])
  @@map("user_has_collectible")
}

model UserHasItem {
  fid       Int
  itemId    Int
  mode      String
  quantity  Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  user      User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_item_itemid_fkey")

  @@id([fid, itemId, mode])
  @@map("user_has_item")
}

model UserHasQuest {
  id          Int       @id @default(autoincrement())
  fid         Int
  questId     Int
  mode        String
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  progress    Int
  status      String    @default("incomplete")
  user        User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_has_quest_questid_fkey")

  @@map("user_has_quest")
}

model UserLeaderboardEntry {
  fid          Int
  mode         String
  currentScore Int      @default(0)
  lastScore    Int      @default(0)
  league       Int      @default(0)
  lastLeague   Int      @default(0)
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @db.Timestamptz(6)
  user         User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, mode])
  @@map("user_leaderboard_entry")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model UserStatistic {
  fid        Int
  mode       Int
  xp         Int
  coins      Int
  expansions Int
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  user       User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, mode])
  @@map("user_statistic")
}
