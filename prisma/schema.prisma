generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  fid                 Int                @unique
  username            String
  displayName         String
  avatarUrl           String?
  walletAddress       String?
  xp                  Int                @default(0)
  coins               Int                @default(0)
  expansions          Int                @default(0)
  notificationDetails String?
  createdAt           DateTime           @default(now())
  items               UserHasItem[]
  gridCells           GridCell[]
  notifications       UserNotification[]
  requests            Request[]
  quests              UserHasQuest[]
  referrals           Referral[]         @relation("Referrer")
  referredBy          Referral[]         @relation("Referred")

  @@map("users")
}

model Item {
  id            Int           @id @default(autoincrement())
  name          String
  description   String?
  icon          String
  category      String
  buyPrice      Int?
  sellPrice     Int?
  requiredLevel Int?
  slug          String        @unique
  createdAt     DateTime      @default(now())
  userItems     UserHasItem[]
  requests      Request[]
  quests        Quest[]
  GridCell      GridCell[]

  @@map("items")
}

model UserHasItem {
  user      User     @relation(fields: [userFid], references: [fid])
  userFid   Int
  item      Item     @relation(fields: [itemId], references: [id])
  itemId    Int
  quantity  Int
  createdAt DateTime @default(now())

  @@unique([userFid, itemId])
  @@map("user_has_items")
}

model Referral {
  id          Int      @id @default(autoincrement())
  referrer    User     @relation("Referrer", fields: [fid], references: [fid])
  fid         Int
  referred    User     @relation("Referred", fields: [referredFid], references: [fid])
  referredFid Int
  createdAt   DateTime @default(now())

  @@unique([fid, referredFid])
  @@map("referrals")
}

model GridCell {
  user             User      @relation(fields: [fid], references: [fid])
  fid              Int
  x                Int
  y                Int
  crop             Item?     @relation(fields: [cropType], references: [slug])
  cropType         String?
  plantedAt        DateTime?
  isReadyToHarvest Boolean   @default(false)
  harvestAt        DateTime?
  speedBoostedAt   DateTime?
  yieldBoost       Float?
  createdAt        DateTime  @default(now())

  @@unique([fid, x, y])
  @@map("user_grid_cells")
}

model UserNotification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [fid], references: [fid])
  fid       Int
  category  String
  createdAt DateTime @default(now())

  @@map("user_notification")
}

model Request {
  id             Int      @id @default(autoincrement())
  user           User     @relation(fields: [fid], references: [fid])
  fid            Int
  item           Item     @relation(fields: [itemId], references: [id])
  itemId         Int
  quantity       Int
  filledQuantity Int      @default(0)
  createdAt      DateTime @default(now())

  @@map("requests")
}

model Quest {
  id         Int            @id @default(autoincrement())
  category   String
  type       QuestType?
  item       Item?          @relation(fields: [itemId], references: [id])
  itemId     Int?
  amount     Int?
  xp         Int?
  coins      Int?
  startAt    DateTime?
  endAt      DateTime?
  level      Int?
  createdAt  DateTime       @default(now())
  userQuests UserHasQuest[]

  @@map("quests")
}

model UserHasQuest {
  id          Int       @id @default(autoincrement())
  user        User      @relation(fields: [fid], references: [fid])
  fid         Int
  quest       Quest     @relation(fields: [questId], references: [id])
  questId     Int
  status      String    @default("incomplete")
  progress    Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([fid, questId])
  @@map("user_has_quests")
}

enum QuestType {
  daily
  weekly
  monthly
}
