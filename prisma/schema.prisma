generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  fid                 Decimal            @id @db.Decimal
  username            String
  displayName         String
  avatarUrl           String?
  walletAddress       String?
  xp                  Decimal            @default(0) @db.Decimal
  coins               Decimal            @default(0) @db.Decimal
  expansions          Decimal            @default(0) @db.Decimal
  notificationDetails String?
  createdAt           DateTime           @default(now()) @db.Timestamptz(6)
  referrals           Referral[]         @relation("Referrer")
  requests            Request[]
  gridCells           GridCell[]
  items               UserHasItem[]
  quests              UserHasQuest[]
  notifications       UserNotification[]

  @@map("users")
}

model Item {
  id            BigInt        @id @default(autoincrement())
  name          String
  description   String?
  icon          String
  category      String
  buyPrice      Decimal?      @db.Decimal
  sellPrice     Decimal?      @db.Decimal
  requiredLevel Decimal       @default(1) @db.Decimal
  createdAt     DateTime      @default(now()) @db.Timestamptz(6)
  slug          String?       @unique
  quests        Quest[]
  requests      Request[]
  GridCell      GridCell[]
  userItems     UserHasItem[]

  @@map("items")
}

model UserHasItem {
  userFid   Decimal  @db.Decimal
  itemId    BigInt
  quantity  Decimal  @default(1) @db.Decimal
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user      User     @relation(fields: [userFid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@id([userFid, itemId])
  @@map("user_has_items")
}

model Referral {
  id          BigInt   @id @default(autoincrement())
  fid         Decimal  @db.Decimal
  referredFid Decimal  @db.Decimal
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  referrer    User     @relation("Referrer", fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@map("referrals")
}

model GridCell {
  fid              Decimal   @db.Decimal
  x                BigInt
  y                BigInt
  cropType         String?
  plantedAt        DateTime? @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @db.Timestamptz(6)
  isReadyToHarvest Boolean   @default(false)
  yieldBoost       Decimal?  @db.Decimal
  speedBoostedAt   DateTime? @db.Timestamptz(6)
  harvestAt        DateTime? @db.Timestamptz(6)
  user             User      @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction, map: "player_grid_cells_fid_fkey")
  crop             Item?     @relation(fields: [cropType], references: [slug], onDelete: NoAction, onUpdate: NoAction)

  @@id([fid, x, y])
  @@map("user_grid_cells")
}

model UserNotification {
  id         BigInt   @id @default(autoincrement())
  fid        Decimal  @db.Decimal
  created_at DateTime @default(now()) @db.Timestamptz(6)
  category   String   @db.VarChar
  user       User     @relation(fields: [fid], references: [fid], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_notification")
}

model Request {
  id             BigInt   @id @default(autoincrement())
  fid            Decimal  @db.Decimal
  itemId         BigInt?
  quantity       Decimal? @db.Decimal
  filledQuantity Decimal  @default(0) @db.Decimal
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  user           User     @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  item           Item?    @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("requests")
}

model Quest {
  id         BigInt         @id @default(autoincrement())
  category   String
  itemId     BigInt?
  amount     Decimal?       @db.Decimal
  xp         Decimal?       @db.Decimal
  coins      Decimal?       @db.Decimal
  startAt    DateTime       @db.Timestamptz(6)
  endAt      DateTime?      @db.Timestamptz(6)
  createdAt  DateTime       @default(now()) @db.Timestamptz(6)
  type       String?
  level      Decimal?       @db.Decimal
  item       Item?          @relation(fields: [itemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  userQuests UserHasQuest[]

  @@map("quests")
}

model UserHasQuest {
  id          BigInt    @id @default(autoincrement())
  fid         Decimal   @db.Decimal
  questId     BigInt
  completedAt DateTime? @db.Timestamptz(6)
  createdAt   DateTime  @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  progress    Decimal   @default(0) @db.Decimal
  status      String    @default("incomplete")
  user        User      @relation(fields: [fid], references: [fid], onDelete: NoAction, onUpdate: NoAction)
  quest       Quest     @relation(fields: [questId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([fid, questId], map: "user_has_quests_fid_quest_id_key")
  @@index([fid], map: "idx_user_has_quests_fid")
  @@index([questId], map: "idx_user_has_quests_quest_id")
  @@index([fid])
  @@index([questId], map: "user_has_quests_quest_id_idx")
  @@map("user_has_quests")
}

enum UserHasQuestStatus {
  incomplete
  completed
  claimed
}
